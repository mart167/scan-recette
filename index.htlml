<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#E8602C">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="ScanRecette">
<title>ScanRecette</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,700;0,900;1,300&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
:root {
  --orange: #E8602C;
  --dark: #1A1208;
  --cream: #F5F0E8;
  --green: #3D6B3A;
  --gray: #9A9A9A;
  --light-gray: #F0EDE8;
  --safe-bottom: env(safe-area-inset-bottom, 20px);
  --safe-top: env(safe-area-inset-top, 0px);
}
body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--dark); height: 100dvh; overflow: hidden; position: fixed; width: 100%; }
.app { height: 100dvh; display: flex; flex-direction: column; position: relative; overflow: hidden; }
.screen { position: absolute; inset: 0; bottom: 70px; overflow-y: auto; -webkit-overflow-scrolling: touch; opacity: 0; pointer-events: none; transform: translateX(30px); transition: opacity 0.35s ease, transform 0.35s ease; }
.screen.active { opacity: 1; pointer-events: all; transform: translateX(0); }
.bottom-nav { position: fixed; bottom: 0; left: 0; right: 0; height: calc(70px + var(--safe-bottom)); background: white; display: flex; justify-content: space-around; align-items: flex-start; padding-top: 10px; border-top: 1px solid rgba(0,0,0,0.08); z-index: 100; box-shadow: 0 -8px 30px rgba(0,0,0,0.06); }
.nav-item { display: flex; flex-direction: column; align-items: center; gap: 4px; cursor: pointer; padding: 4px 20px; border-radius: 12px; transition: all 0.2s ease; }
.nav-icon { font-size: 24px; transition: transform 0.2s ease; }
.nav-label { font-size: 10px; font-weight: 600; color: var(--gray); letter-spacing: 0.5px; transition: color 0.2s ease; }
.nav-item.active .nav-label { color: var(--orange); }
.nav-item.active .nav-icon { transform: scale(1.15); }

/* ACCUEIL */
#screen-home { background: var(--cream); }
.home-header { background: var(--orange); padding: calc(var(--safe-top) + 20px) 24px 28px; position: relative; overflow: hidden; }
.home-header::before { content: ''; position: absolute; top: -40px; right: -40px; width: 200px; height: 200px; background: rgba(255,255,255,0.1); border-radius: 50%; }
.home-greeting { font-size: 12px; color: rgba(255,255,255,0.7); letter-spacing: 2px; text-transform: uppercase; font-weight: 500; }
.home-title { font-family: 'Fraunces', serif; font-size: 28px; font-weight: 900; color: white; line-height: 1.2; margin-top: 4px; position: relative; z-index: 1; }
.home-body { padding: 24px; }
.scan-card { background: var(--dark); border-radius: 24px; padding: 24px; display: flex; align-items: center; gap: 16px; cursor: pointer; transition: transform 0.15s ease; box-shadow: 0 8px 30px rgba(26,18,8,0.2); }
.scan-card:active { transform: scale(0.97); }
.scan-card-icon { width: 56px; height: 56px; background: var(--orange); border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 28px; flex-shrink: 0; }
.scan-card-text .t1 { font-family: 'Fraunces', serif; font-size: 18px; font-weight: 700; color: white; }
.scan-card-text .t2 { font-size: 12px; color: rgba(255,255,255,0.5); margin-top: 3px; }
.scan-card-arrow { margin-left: auto; color: rgba(255,255,255,0.3); font-size: 20px; }
.section-title { font-family: 'Fraunces', serif; font-size: 20px; font-weight: 700; color: var(--dark); margin: 24px 0 14px; }
.recipe-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.recipe-mini { background: white; border-radius: 16px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.06); cursor: pointer; transition: transform 0.15s ease; }
.recipe-mini:active { transform: scale(0.97); }
.recipe-mini-emoji { height: 80px; display: flex; align-items: center; justify-content: center; font-size: 40px; }
.recipe-mini-info { padding: 10px 12px 12px; }
.recipe-mini-name { font-family: 'Fraunces', serif; font-size: 13px; font-weight: 700; color: var(--dark); line-height: 1.3; }
.recipe-mini-meta { font-size: 10px; color: var(--gray); margin-top: 4px; }

/* SCANNER */
#screen-scan { background: var(--dark); display: flex; flex-direction: column; }
.scan-header { padding: calc(var(--safe-top) + 16px) 24px 16px; background: var(--dark); }
.scan-header-title { font-family: 'Fraunces', serif; font-size: 24px; font-weight: 900; color: white; }
.scan-header-sub { font-size: 12px; color: rgba(255,255,255,0.4); margin-top: 3px; }
.camera-container { flex: 1; margin: 0 16px; position: relative; border-radius: 24px; overflow: hidden; background: #0A0804; min-height: 240px; max-height: 300px; }
#camera-preview { width: 100%; height: 100%; object-fit: cover; display: none; }
#captured-image { width: 100%; height: 100%; object-fit: cover; display: none; }
.camera-overlay { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 8px; }
.camera-placeholder { text-align: center; color: rgba(255,255,255,0.3); }
.camera-placeholder .cp-icon { font-size: 48px; }
.camera-placeholder .cp-text { font-size: 13px; margin-top: 8px; }
.corner { position: absolute; width: 24px; height: 24px; border-color: var(--orange); border-style: solid; }
.corner.tl { top: 16px; left: 16px; border-width: 3px 0 0 3px; border-radius: 4px 0 0 0; }
.corner.tr { top: 16px; right: 16px; border-width: 3px 3px 0 0; border-radius: 0 4px 0 0; }
.corner.bl { bottom: 16px; left: 16px; border-width: 0 0 3px 3px; border-radius: 0 0 0 4px; }
.corner.br { bottom: 16px; right: 16px; border-width: 0 3px 3px 0; border-radius: 0 0 4px 0; }
.scan-actions { padding: 12px 16px; display: flex; flex-direction: column; gap: 10px; }
.btn-primary { background: var(--orange); color: white; border: none; border-radius: 16px; padding: 16px; font-family: 'Fraunces', serif; font-size: 16px; font-weight: 700; cursor: pointer; width: 100%; transition: transform 0.15s, opacity 0.15s; display: flex; align-items: center; justify-content: center; gap: 8px; }
.btn-primary:active { transform: scale(0.97); opacity: 0.9; }
.btn-primary:disabled { opacity: 0.5; }
.btn-secondary { background: rgba(255,255,255,0.08); color: white; border: 1.5px solid rgba(255,255,255,0.15); border-radius: 16px; padding: 14px; font-size: 14px; font-weight: 500; cursor: pointer; width: 100%; transition: transform 0.15s; display: flex; align-items: center; justify-content: center; gap: 8px; }
.btn-secondary:active { transform: scale(0.97); }
.loading-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.75); display: none; align-items: center; justify-content: center; flex-direction: column; gap: 12px; border-radius: 24px; }
.loading-overlay.show { display: flex; }
.spinner { width: 40px; height: 40px; border: 3px solid rgba(255,255,255,0.2); border-top-color: var(--orange); border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { color: white; font-size: 13px; font-weight: 500; }

/* RECETTES IA */
.result-section { padding: 0 16px 16px; display: none; flex-direction: column; gap: 8px; }
.result-section.show { display: flex; }
.result-label { font-family: 'Fraunces', serif; font-size: 14px; font-weight: 700; color: rgba(255,255,255,0.5); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px; }
.ai-card { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 16px 20px; cursor: pointer; transition: all 0.2s ease; display: flex; align-items: center; gap: 14px; }
.ai-card:active { transform: scale(0.97); background: rgba(255,255,255,0.13); }
.ai-card-emoji { font-size: 26px; flex-shrink: 0; }
.ai-card-info { flex: 1; }
.ai-card-title { font-family: 'Fraunces', serif; font-size: 16px; font-weight: 700; color: white; line-height: 1.3; }
.ai-card-time { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 3px; }
.ai-card-arrow { color: rgba(255,255,255,0.25); font-size: 20px; }

/* RECETTES PAGE */
#screen-recipes { background: var(--cream); }
.recipes-header { background: var(--green); padding: calc(var(--safe-top) + 20px) 24px 24px; }
.recipes-header-title { font-family: 'Fraunces', serif; font-size: 28px; font-weight: 900; color: white; }
.search-bar { margin-top: 14px; background: rgba(255,255,255,0.15); border-radius: 14px; padding: 12px 16px; display: flex; align-items: center; gap: 10px; }
.search-bar input { background: none; border: none; outline: none; color: white; font-size: 14px; width: 100%; font-family: 'DM Sans', sans-serif; }
.search-bar input::placeholder { color: rgba(255,255,255,0.5); }
.filters-row { display: flex; gap: 8px; padding: 16px 24px 0; overflow-x: auto; -ms-overflow-style: none; scrollbar-width: none; }
.filters-row::-webkit-scrollbar { display: none; }
.filter-chip { padding: 7px 16px; border-radius: 20px; font-size: 12px; font-weight: 600; border: 1.5px solid #D4C4A0; color: var(--dark); white-space: nowrap; cursor: pointer; transition: all 0.2s; flex-shrink: 0; }
.filter-chip.active { background: var(--dark); border-color: var(--dark); color: white; }
.recipes-list { padding: 16px 24px 24px; display: flex; flex-direction: column; gap: 12px; }
.recipe-card { background: white; border-radius: 20px; overflow: hidden; display: flex; box-shadow: 0 2px 16px rgba(0,0,0,0.07); cursor: pointer; transition: transform 0.15s; }
.recipe-card:active { transform: scale(0.98); }
.recipe-card-emoji { width: 88px; display: flex; align-items: center; justify-content: center; font-size: 40px; flex-shrink: 0; }
.recipe-card-info { padding: 14px 14px 14px 0; flex: 1; }
.recipe-card-name { font-family: 'Fraunces', serif; font-size: 15px; font-weight: 700; color: var(--dark); line-height: 1.3; }
.recipe-card-meta { display: flex; gap: 10px; margin-top: 6px; }
.recipe-badge { font-size: 11px; color: var(--gray); }
.recipe-tags { display: flex; gap: 5px; margin-top: 8px; flex-wrap: wrap; }
.recipe-tag { background: var(--light-gray); border-radius: 6px; padding: 3px 8px; font-size: 10px; font-weight: 500; color: var(--dark); }

/* MODAL */
.modal { position: fixed; inset: 0; z-index: 300; display: none; }
.modal.show { display: block; }
.modal-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.5); }
.modal-content { position: absolute; bottom: 0; left: 0; right: 0; background: var(--cream); border-radius: 28px 28px 0 0; max-height: 88vh; overflow-y: auto; padding: 20px 24px calc(40px + var(--safe-bottom)); animation: slideUp 0.35s ease; }
@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
.modal-handle { width: 40px; height: 4px; background: rgba(0,0,0,0.15); border-radius: 2px; margin: 0 auto 20px; }
.modal-close { position: absolute; top: 20px; right: 20px; width: 32px; height: 32px; background: rgba(0,0,0,0.08); border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 14px; border: none; }
.modal-emoji-big { font-size: 48px; display: block; margin-bottom: 10px; }
.modal-title { font-family: 'Fraunces', serif; font-size: 22px; font-weight: 900; color: var(--dark); line-height: 1.2; margin-bottom: 20px; }
.modal-section { margin-bottom: 20px; }
.modal-section-title { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--orange); margin-bottom: 10px; }
.modal-section-body { font-size: 14px; color: var(--dark); line-height: 1.8; opacity: 0.8; }
.modal-ingredient { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 1px solid rgba(0,0,0,0.06); font-size: 14px; color: var(--dark); }
.modal-ingredient::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--orange); flex-shrink: 0; }
.modal-step { display: flex; gap: 12px; margin-bottom: 14px; }
.modal-step-num { width: 24px; height: 24px; background: var(--dark); color: white; border-radius: 50%; font-size: 11px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px; }
.modal-step-text { font-size: 14px; color: var(--dark); line-height: 1.6; opacity: 0.8; flex: 1; }

/* TOAST */
.toast { position: fixed; bottom: 90px; left: 50%; transform: translateX(-50%) translateY(20px); background: var(--dark); color: white; padding: 12px 20px; border-radius: 12px; font-size: 13px; font-weight: 500; opacity: 0; transition: all 0.3s ease; z-index: 200; white-space: nowrap; pointer-events: none; }
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
#file-input { display: none; }
</style>
</head>
<body>
<div class="app">

  <!-- ACCUEIL -->
  <div class="screen active" id="screen-home">
    <div class="home-header">
      <div class="home-greeting">👋 Bonjour</div>
      <div class="home-title">Qu'est-ce qu'on<br>mange ce soir ?</div>
    </div>
    <div class="home-body">
      <div class="scan-card" onclick="showScreen('scan')">
        <div class="scan-card-icon">📷</div>
        <div class="scan-card-text">
          <div class="t1">Scanner mon frigo</div>
          <div class="t2">Photo → Recettes en quelques secondes</div>
        </div>
        <div class="scan-card-arrow">›</div>
      </div>
      <div class="section-title">Recettes populaires</div>
      <div class="recipe-grid">
        <div class="recipe-mini" onclick="showScreen('recipes')">
          <div class="recipe-mini-emoji" style="background:linear-gradient(135deg,#FFF3E0,#FFE0B2)">🥘</div>
          <div class="recipe-mini-info"><div class="recipe-mini-name">Quiche aux œufs</div><div class="recipe-mini-meta">⏱ 30 min</div></div>
        </div>
        <div class="recipe-mini" onclick="showScreen('recipes')">
          <div class="recipe-mini-emoji" style="background:linear-gradient(135deg,#E8F5E9,#C8E6C9)">🍳</div>
          <div class="recipe-mini-info"><div class="recipe-mini-name">Omelette provençale</div><div class="recipe-mini-meta">⏱ 10 min</div></div>
        </div>
        <div class="recipe-mini" onclick="showScreen('recipes')">
          <div class="recipe-mini-emoji" style="background:linear-gradient(135deg,#FCE4EC,#F8BBD0)">🍝</div>
          <div class="recipe-mini-info"><div class="recipe-mini-name">Pasta tomate</div><div class="recipe-mini-meta">⏱ 20 min</div></div>
        </div>
        <div class="recipe-mini" onclick="showScreen('recipes')">
          <div class="recipe-mini-emoji" style="background:linear-gradient(135deg,#E3F2FD,#BBDEFB)">🥗</div>
          <div class="recipe-mini-info"><div class="recipe-mini-name">Salade césar</div><div class="recipe-mini-meta">⏱ 15 min</div></div>
        </div>
      </div>
    </div>
  </div>

  <!-- SCANNER -->
  <div class="screen" id="screen-scan">
    <div class="scan-header">
      <div class="scan-header-title">📷 Scanner</div>
      <div class="scan-header-sub">Prends une photo de ton frigo ou de tes ingrédients</div>
    </div>
    <div class="camera-container">
      <video id="camera-preview" autoplay playsinline muted></video>
      <img id="captured-image" alt="Photo">
      <div class="corner tl"></div><div class="corner tr"></div>
      <div class="corner bl"></div><div class="corner br"></div>
      <div class="camera-overlay" id="camera-placeholder">
        <div class="camera-placeholder">
          <div class="cp-icon">📸</div>
          <div class="cp-text">Appuie sur "Prendre une photo"</div>
        </div>
      </div>
      <div class="loading-overlay" id="loading-overlay">
        <div class="spinner"></div>
        <div class="loading-text">Analyse en cours... ✨</div>
      </div>
    </div>
    <div class="scan-actions">
      <button class="btn-primary" id="btn-capture" onclick="capturePhoto()">📷 Prendre une photo</button>
      <button class="btn-secondary" id="btn-analyze" onclick="analyzePhoto()" style="display:none">🔍 Analyser les ingrédients</button>
      <button class="btn-secondary" id="btn-retry" onclick="retryPhoto()" style="display:none">🔄 Reprendre une photo</button>
    </div>
    <div class="result-section" id="result-section">
      <div class="result-label">🍽️ Recettes suggérées</div>
      <div id="ai-cards-container"></div>
    </div>
  </div>

  <!-- RECETTES -->
  <div class="screen" id="screen-recipes">
    <div class="recipes-header">
      <div class="recipes-header-title">📚 Recettes</div>
      <div class="search-bar">
        <span style="color:rgba(255,255,255,0.5)">🔍</span>
        <input type="text" placeholder="Chercher une recette..." id="search-input" oninput="filterRecipes()">
      </div>
    </div>
    <div class="filters-row">
      <div class="filter-chip active" onclick="setFilter(this,'all')">Toutes</div>
      <div class="filter-chip" onclick="setFilter(this,'rapide')">⚡ Rapide</div>
      <div class="filter-chip" onclick="setFilter(this,'vege')">🥦 Végé</div>
      <div class="filter-chip" onclick="setFilter(this,'leger')">🥗 Léger</div>
      <div class="filter-chip" onclick="setFilter(this,'pasta')">🍝 Pasta</div>
    </div>
    <div class="recipes-list" id="recipes-list"></div>
  </div>

  <!-- NAV -->
  <nav class="bottom-nav">
    <div class="nav-item active" id="nav-home" onclick="showScreen('home')">
      <div class="nav-icon">🏠</div><div class="nav-label">Accueil</div>
    </div>
    <div class="nav-item" id="nav-scan" onclick="showScreen('scan')">
      <div class="nav-icon">📷</div><div class="nav-label">Scanner</div>
    </div>
    <div class="nav-item" id="nav-recipes" onclick="showScreen('recipes')">
      <div class="nav-icon">📚</div><div class="nav-label">Recettes</div>
    </div>
  </nav>
</div>

<!-- MODAL -->
<div class="modal" id="recipe-modal">
  <div class="modal-backdrop" onclick="closeModal()"></div>
  <div class="modal-content">
    <div class="modal-handle"></div>
    <button class="modal-close" onclick="closeModal()">✕</button>
    <span class="modal-emoji-big" id="modal-emoji">🍽️</span>
    <div class="modal-title" id="modal-title"></div>
    <div class="modal-section">
      <div class="modal-section-title">Ingrédients</div>
      <div id="modal-ingredients"></div>
    </div>
    <div class="modal-section">
      <div class="modal-section-title">Préparation</div>
      <div id="modal-steps"></div>
    </div>
  </div>
</div>

<input type="file" id="file-input" accept="image/*" capture="environment" onchange="handleFileSelect(event)">
<div class="toast" id="toast"></div>

<script>
const GEMINI_KEY = ['AIzaSyB0n914','DUFvGgP-aFDZ','LEW8v8wKIO1gdDc'].join('');
const GEMINI_URL = 'https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=' + GEMINI_KEY;
const EMOJIS = ['🥘','🍳','🫕','🍝','🥗','🍲','🍜','🫑','🥙','🌮'];

let stream = null;
let capturedBase64 = null;
let parsedRecipes = [];
let currentFilter = 'all';

const recipes = [
  { name:'Quiche aux œufs & fromage', emoji:'🥘', time:'30 min', people:'2', tags:['vege'], bg:'linear-gradient(135deg,#FFF3E0,#FFE0B2)' },
  { name:'Omelette provençale', emoji:'🍳', time:'10 min', people:'1', tags:['rapide','vege','leger'], bg:'linear-gradient(135deg,#E8F5E9,#C8E6C9)' },
  { name:'Gratin dauphinois', emoji:'🫕', time:'45 min', people:'4', tags:['vege'], bg:'linear-gradient(135deg,#FCE4EC,#F8BBD0)' },
  { name:'Pasta tomate basilic', emoji:'🍝', time:'20 min', people:'2', tags:['rapide','vege','pasta'], bg:'linear-gradient(135deg,#FFEBEE,#FFCDD2)' },
  { name:'Salade césar', emoji:'🥗', time:'15 min', people:'2', tags:['rapide','leger'], bg:'linear-gradient(135deg,#E3F2FD,#BBDEFB)' },
  { name:'Soupe de légumes', emoji:'🍲', time:'25 min', people:'4', tags:['vege','leger'], bg:'linear-gradient(135deg,#F3E5F5,#E1BEE7)' },
  { name:'Carbonara maison', emoji:'🍜', time:'20 min', people:'2', tags:['rapide','pasta'], bg:'linear-gradient(135deg,#FFF8E1,#FFECB3)' },
];

function showScreen(name) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('screen-' + name).classList.add('active');
  document.getElementById('nav-' + name).classList.add('active');
  if (name === 'scan') startCamera();
  else stopCamera();
}

async function startCamera() {
  try {
    stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
    const v = document.getElementById('camera-preview');
    v.srcObject = stream;
    v.style.display = 'block';
    document.getElementById('camera-placeholder').style.display = 'none';
  } catch(e) { console.log('Camera fallback'); }
}

function stopCamera() {
  if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
}

function capturePhoto() {
  if (stream) {
    const v = document.getElementById('camera-preview');
    const c = document.createElement('canvas');
    c.width = v.videoWidth || 640; c.height = v.videoHeight || 480;
    c.getContext('2d').drawImage(v, 0, 0);
    capturedBase64 = c.toDataURL('image/jpeg', 0.8).split(',')[1];
    const img = document.getElementById('captured-image');
    img.src = c.toDataURL('image/jpeg', 0.8);
    img.style.display = 'block';
    v.style.display = 'none';
    showCaptureControls();
  } else {
    document.getElementById('file-input').click();
  }
}

function handleFileSelect(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (ev) => {
    capturedBase64 = ev.target.result.split(',')[1];
    const img = document.getElementById('captured-image');
    img.src = ev.target.result;
    img.style.display = 'block';
    document.getElementById('camera-preview').style.display = 'none';
    document.getElementById('camera-placeholder').style.display = 'none';
    showCaptureControls();
  };
  reader.readAsDataURL(file);
}

function showCaptureControls() {
  document.getElementById('btn-capture').style.display = 'none';
  document.getElementById('btn-analyze').style.display = 'flex';
  document.getElementById('btn-retry').style.display = 'flex';
}

function retryPhoto() {
  capturedBase64 = null;
  document.getElementById('captured-image').style.display = 'none';
  document.getElementById('btn-capture').style.display = 'flex';
  document.getElementById('btn-analyze').style.display = 'none';
  document.getElementById('btn-retry').style.display = 'none';
  document.getElementById('result-section').classList.remove('show');
  document.getElementById('ai-cards-container').innerHTML = '';
  startCamera();
}

async function analyzePhoto() {
  if (!capturedBase64) { showToast('Prends d\'abord une photo !'); return; }
  document.getElementById('loading-overlay').classList.add('show');
  document.getElementById('btn-analyze').disabled = true;
  try {
    const res = await fetch(GEMINI_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        contents: [{
          parts: [
            { text: `Analyse cette photo et retourne EXACTEMENT 3 recettes. Format strict sans introduction :

1. [Nom recette]
Temps : X min
Personnes : X
Ingrédients :
- ingrédient 1
- ingrédient 2
Préparation :
1. étape
2. étape

2. [Nom recette]
Temps : X min
Personnes : X
Ingrédients :
- ingrédient 1
Préparation :
1. étape

3. [Nom recette]
Temps : X min
Personnes : X
Ingrédients :
- ingrédient 1
Préparation :
1. étape

Commence directement par "1." sans aucun texte avant. Pas d'astérisques. En français uniquement.` },
            { inline_data: { mime_type: 'image/jpeg', data: capturedBase64 } }
          ]
        }]
      })
    });
    const data = await res.json();
    if (data.candidates && data.candidates[0]) {
      const text = data.candidates[0].content.parts[0].text;
      parseAndDisplayRecipes(text);
      showToast('✅ Recettes trouvées !');
    } else { throw new Error('No response'); }
  } catch(err) {
    console.error(err);
    showToast('❌ Erreur — Vérifie ta connexion');
  } finally {
    document.getElementById('loading-overlay').classList.remove('show');
    document.getElementById('btn-analyze').disabled = false;
  }
}

function parseAndDisplayRecipes(text) {
  // Découpe sur les numéros 1. 2. 3.
  const parts = text.split(/(?=^\d+\. )/m).map(s => s.trim()).filter(s => /^\d+\./.test(s) && s.length > 20);
  parsedRecipes = parts.length > 0 ? parts : [text];

  const container = document.getElementById('ai-cards-container');
  container.innerHTML = parsedRecipes.map((r, i) => {
    const lines = r.split('\n').filter(l => l.trim());
    let title = lines[0].replace(/^\d+\.\s*/, '').replace(/[*#]/g, '').trim();
    if (!title || title.length < 2) title = 'Recette ' + (i + 1);
    const timeMatch = r.match(/(\d+)\s*min/i);
    const time = timeMatch ? timeMatch[1] + ' min' : '~20 min';
    return `<div class="ai-card" onclick="openRecipeModal(${i})">
      <div class="ai-card-emoji">${EMOJIS[i % EMOJIS.length]}</div>
      <div class="ai-card-info">
        <div class="ai-card-title">${title}</div>
        <div class="ai-card-time">⏱ ${time} · Appuie pour voir la recette</div>
      </div>
      <div class="ai-card-arrow">›</div>
    </div>`;
  }).join('');

  document.getElementById('result-section').classList.add('show');
}

function openRecipeModal(i) {
  const recipe = parsedRecipes[i];
  if (!recipe) return;

  const lines = recipe.split('\n').map(l => l.trim()).filter(l => l);
  let title = lines[0].replace(/^\d+\.\s*/, '').replace(/[*#]/g, '').trim();

  // Parse ingrédients et étapes
  let inIngredients = false, inSteps = false;
  const ingredients = [], steps = [];

  lines.slice(1).forEach(line => {
    if (/^ingr/i.test(line)) { inIngredients = true; inSteps = false; return; }
    if (/^prép|^étapes|^instructions/i.test(line)) { inSteps = true; inIngredients = false; return; }
    if (/^temps|^personnes/i.test(line)) return;
    if (inIngredients && line.startsWith('-')) ingredients.push(line.replace(/^-\s*/, ''));
    if (inSteps && /^\d+\./.test(line)) steps.push(line.replace(/^\d+\.\s*/, ''));
  });

  document.getElementById('modal-emoji').textContent = EMOJIS[i % EMOJIS.length];
  document.getElementById('modal-title').textContent = title;
  document.getElementById('modal-ingredients').innerHTML = ingredients.length > 0
    ? ingredients.map(ing => `<div class="modal-ingredient">${ing}</div>`).join('')
    : `<div class="modal-section-body" style="opacity:0.5">Ingrédients non détectés</div>`;
  document.getElementById('modal-steps').innerHTML = steps.length > 0
    ? steps.map((s, j) => `<div class="modal-step"><div class="modal-step-num">${j+1}</div><div class="modal-step-text">${s}</div></div>`).join('')
    : `<div class="modal-section-body" style="opacity:0.5">Étapes non détectées</div>`;

  document.getElementById('recipe-modal').classList.add('show');
}

function closeModal() { document.getElementById('recipe-modal').classList.remove('show'); }

function renderRecipes(list) {
  document.getElementById('recipes-list').innerHTML = list.map(r => `
    <div class="recipe-card">
      <div class="recipe-card-emoji" style="background:${r.bg}">${r.emoji}</div>
      <div class="recipe-card-info">
        <div class="recipe-card-name">${r.name}</div>
        <div class="recipe-card-meta"><span class="recipe-badge">⏱ ${r.time}</span><span class="recipe-badge">👤 ${r.people} pers.</span></div>
        <div class="recipe-tags">${r.tags.map(t => `<span class="recipe-tag">${t}</span>`).join('')}</div>
      </div>
    </div>`).join('');
}

function filterRecipes() {
  const search = document.getElementById('search-input').value.toLowerCase();
  let filtered = recipes;
  if (currentFilter !== 'all') filtered = filtered.filter(r => r.tags.includes(currentFilter));
  if (search) filtered = filtered.filter(r => r.name.toLowerCase().includes(search));
  renderRecipes(filtered);
}

function setFilter(el, filter) {
  document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  currentFilter = filter;
  filterRecipes();
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}

renderRecipes(recipes);
</script>
</body>
</html>
